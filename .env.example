# ============================================================
# Document Agentic RAG — Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================

# Required — LLM API (all calls go through OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required — Database (password can contain special characters like @!#$)
DB_USER=scoutrag
DB_PASS=change-this-password
DB_DATABASE=scoutragdb
# DB_HOST=db  (auto-set by Docker Compose, only change for external DB)

# Server port (default: 80)
PORT=80

# Optional — Override models without redeploying (defaults shown)
# ROUTER_MODEL=google/gemini-2.0-flash-001
# VISION_MODEL=google/gemini-3-flash-preview
# EMBEDDING_MODEL=text-embedding-3-small
# LOG_LEVEL=INFO

# Security — Admin login (leave empty for dev mode = no login)
ADMIN_USER=admin
ADMIN_PASS=change-me

# Security — CORS origins (comma-separated, * for dev)
ALLOWED_ORIGINS=*
